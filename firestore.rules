rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /conversations/{convId} {
      allow read, list: if request.auth != null && request.auth.uid == resource.data.uid;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.uid;
      allow update, delete: if request.auth != null && request.auth.uid == resource.data.uid;
    }

    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
      allow read: if request.auth != null && request.auth.token.email == 'shakilxvs@gmail.com';
      allow write: if request.auth != null && request.auth.token.email == 'shakilxvs@gmail.com';
    }

    match /admin/{docId} {
      allow read, write: if request.auth != null && request.auth.token.email == 'shakilxvs@gmail.com';
    }
  }
}
